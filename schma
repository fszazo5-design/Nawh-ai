-- ==========================================
-- 4. الدوال والتريجرات الذكية للمخازن والمالية والحسابات (النسخة الاحترافية الشاملة)
-- ==========================================

-- [أولاً] تريجر ذكي لمعالجة بنود المشتريات (شراء، تعديل كمية، أو حذف بند بالكامل)
CREATE OR REPLACE FUNCTION "pos".fn_trg_inventory_purchase_items()
RETURNS TRIGGER AS $$
DECLARE
    v_diff_qty NUMERIC(12,3);
BEGIN
    IF (TG_OP = 'INSERT') THEN
        -- زيادة المخزون مباشرة عند الشراء وتحديث التكلفة
        UPDATE "pos".products
        SET stock_qty = stock_qty + NEW.qty,
            cost_price = NEW.unit_cost,
            updated_at = now()
        WHERE id = NEW.product_id;

        -- تسجيل الحركة كوارد مخزني
        INSERT INTO "pos".inventory_transactions (product_id, type, qty, source_type, reference_id, description)
        VALUES (NEW.product_id, 'IN', NEW.qty, 'purchase', NEW.purchase_id, 'إضافة كمية بموجب فاتورة شراء بند: ' || NEW.name);

    ELSIF (TG_OP = 'UPDATE') THEN
        -- حساب فرق الكمية لتعديل المخزن
        v_diff_qty := NEW.qty - OLD.qty;
        
        UPDATE "pos".products
        SET stock_qty = stock_qty + v_diff_qty,
            cost_price = NEW.unit_cost,
            updated_at = now()
        WHERE id = NEW.product_id;

        -- تسجيل تعديل الحركة
        INSERT INTO "pos".inventory_transactions (product_id, type, qty, source_type, reference_id, description)
        VALUES (NEW.product_id, CASE WHEN v_diff_qty >= 0 THEN 'IN' ELSE 'OUT' END, ABS(v_diff_qty), 'purchase', NEW.purchase_id, 'تعديل كمية البند في المشتريات إلى: ' || NEW.qty);

    ELSIF (TG_OP = 'DELETE') THEN
        -- خصم الكمية المحذوفة من المخزن فوراً لإعادة ضبط الرصيد الفعلي
        UPDATE "pos".products
        SET stock_qty = stock_qty - OLD.qty,
            updated_at = now()
        WHERE id = OLD.product_id;

        -- تسجيل الحركة العكسية
        INSERT INTO "pos".inventory_transactions (product_id, type, qty, source_type, reference_id, description)
        VALUES (OLD.product_id, 'OUT', OLD.qty, 'purchase', OLD.purchase_id, 'حذف بند من فاتورة المشتريات: ' || OLD.name);
    END IF;
    
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_inventory_purchase_item_all ON "pos".purchase_items;
CREATE TRIGGER trg_inventory_purchase_item_all
AFTER INSERT OR UPDATE OR DELETE ON "pos".purchase_items
FOR EACH ROW
EXECUTE FUNCTION "pos".fn_trg_inventory_purchase_items();


-- [ثانياً] تريجر ذكي لمعالجة بنود المبيعات (بيع، تعديل كمية مرتجع، أو حذف بند)
CREATE OR REPLACE FUNCTION "pos".fn_trg_inventory_sale_items()
RETURNS TRIGGER AS $$
DECLARE
    v_diff_qty NUMERIC(12,3);
BEGIN
    IF (TG_OP = 'INSERT') THEN
        -- خصم من المخزون مباشرة عند البيع
        UPDATE "pos".products
        SET stock_qty = stock_qty - NEW.qty,
            updated_at = now()
        WHERE id = NEW.product_id;

        -- تسجيل حركة صادر
        INSERT INTO "pos".inventory_transactions (product_id, type, qty, source_type, reference_id, description)
        VALUES (NEW.product_id, 'OUT', NEW.qty, 'invoice', NEW.invoice_id, 'صرف كمية بموجب فاتورة مبيعات بند: ' || NEW.name);

    ELSIF (TG_OP = 'UPDATE') THEN
        -- حساب فرق التعديل للكميات المباعة
        v_diff_qty := NEW.qty - OLD.qty;
        
        UPDATE "pos".products
        SET stock_qty = stock_qty - v_diff_qty,
            updated_at = now()
        WHERE id = NEW.product_id;

        -- توثيق تعديل الكمية مخزنياً
        INSERT INTO "pos".inventory_transactions (product_id, type, qty, source_type, reference_id, description)
        VALUES (NEW.product_id, CASE WHEN v_diff_qty >= 0 THEN 'OUT' ELSE 'IN' END, ABS(v_diff_qty), 'invoice', NEW.invoice_id, 'تعديل كمية البند المباعة إلى: ' || NEW.qty);

    ELSIF (TG_OP = 'DELETE') THEN
        -- إرجاع الكمية بالكامل إلى المخزون عند مسح البند من الفاتورة
        UPDATE "pos".products
        SET stock_qty = stock_qty + OLD.qty,
            updated_at = now()
        WHERE id = OLD.product_id;

        -- تسجيل إعادة السلعة للمخزن
        INSERT INTO "pos".inventory_transactions (product_id, type, qty, source_type, reference_id, description)
        VALUES (OLD.product_id, 'IN', OLD.qty, 'invoice', OLD.invoice_id, 'حذف بند من فاتورة المبيعات وإعادة الكمية للمخزن: ' || OLD.name);
    END IF;
    
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_inventory_sale_item_all ON "pos".invoice_items;
CREATE TRIGGER trg_inventory_sale_item_all
AFTER INSERT OR UPDATE OR DELETE ON "pos".invoice_items
FOR EACH ROW
EXECUTE FUNCTION "pos".fn_trg_inventory_sale_items();


-- [ثالثاً] تريجر معالجة التغيرات المالية في فواتير المبيعات (تعديل الحسابات، الدفع الآجل والتحصيل)
CREATE OR REPLACE FUNCTION "pos".fn_trg_financial_sale_head()
RETURNS TRIGGER AS $$
DECLARE
    v_diff_paid NUMERIC(12,2) := 0;
    v_diff_remain NUMERIC(12,2) := 0;
BEGIN
    -- في حالة الإضافة الجديدة لبيانات الفاتورة
    IF (TG_OP = 'INSERT') THEN
        IF NEW.paid_amount > 0 THEN
            INSERT INTO "pos".cash_flow (type, amount, source_type, reference_id, description)
            VALUES ('IN', NEW.paid_amount, 'invoice', NEW.id, 'تحصيل نقدي لفاتورة مبيعات رقم: ' || NEW.invoice_number);
        END IF;

        IF NEW.remaining_amount > 0 AND NEW.customer_id IS NOT NULL THEN
            UPDATE "pos".customers
            SET current_balance = current_balance + NEW.remaining_amount
            WHERE id = NEW.customer_id;
        END IF;

    -- في حالة تعديل طرق الدفع أو المبالغ المسددة
    ELSIF (TG_OP = 'UPDATE') THEN
        -- تسوية الفروقات النقدية في الخزينة
        v_diff_paid := NEW.paid_amount - OLD.paid_amount;
        IF v_diff_paid <> 0 THEN
            INSERT INTO "pos".cash_flow (type, amount, source_type, reference_id, description)
            VALUES (
                CASE WHEN v_diff_paid > 0 THEN 'IN' ELSE 'OUT' END,
                ABS(v_diff_paid),
                'invoice',
                NEW.id,
                'تعديل المبلغ المحصل لفاتورة رقم: ' || NEW.invoice_number
            );
        END IF;

        -- تسوية الفروقات الآجلة في حسابات العملاء
        v_diff_remain := NEW.remaining_amount - OLD.remaining_amount;
        IF v_diff_remain <> 0 AND NEW.customer_id IS NOT NULL THEN
            UPDATE "pos".customers
            SET current_balance = current_balance + v_diff_remain
            WHERE id = NEW.customer_id;
        END IF;

    -- في حالة حذف الفاتورة بالكامل
    ELSIF (TG_OP = 'DELETE') THEN
        -- استرجاع المال المدفوع من الخزنة
        IF OLD.paid_amount > 0 THEN
            INSERT INTO "pos".cash_flow (type, amount, source_type, reference_id, description)
            VALUES ('OUT', OLD.paid_amount, 'invoice', OLD.id, 'إلغاء واسترداد دفع الفاتورة المحذوفة رقم: ' || OLD.invoice_number);
        END IF;

        -- خصم المبالغ الآجلة التي سجلت على العميل سابقاً
        IF OLD.remaining_amount > 0 AND OLD.customer_id IS NOT NULL THEN
            UPDATE "pos".customers
            SET current_balance = current_balance - OLD.remaining_amount
            WHERE id = OLD.customer_id;
        END IF;
    END IF;

    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_financial_sale_head_all ON "pos".invoices;
CREATE TRIGGER trg_financial_sale_head_all
AFTER INSERT OR UPDATE OR DELETE ON "pos".invoices
FOR EACH ROW
EXECUTE FUNCTION "pos".fn_trg_financial_sale_head();


-- [رابعاً] تريجر معالجة التغيرات المالية لفواتير المشتريات (تحديث حسابات الخزينة والموردين)
CREATE OR REPLACE FUNCTION "pos".fn_trg_financial_purchase_head()
RETURNS TRIGGER AS $$
DECLARE
    v_diff_paid NUMERIC(12,2) := 0;
    v_diff_remain NUMERIC(12,2) := 0;
BEGIN
    IF (TG_OP = 'INSERT') THEN
        IF NEW.paid_amount > 0 THEN
            INSERT INTO "pos".cash_flow (type, amount, source_type, reference_id, description)
            VALUES ('OUT', NEW.paid_amount, 'purchase', NEW.id, 'دفع نقدي لفاتورة شراء رقم: ' || NEW.purchase_number);
        END IF;

        IF NEW.remaining_amount > 0 AND NEW.supplier_id IS NOT NULL THEN
            UPDATE "pos".suppliers
            SET current_balance = current_balance + NEW.remaining_amount
            WHERE id = NEW.supplier_id;
        END IF;

    ELSIF (TG_OP = 'UPDATE') THEN
        v_diff_paid := NEW.paid_amount - OLD.paid_amount;
        IF v_diff_paid <> 0 THEN
            INSERT INTO "pos".cash_flow (type, amount, source_type, reference_id, description)
            VALUES (
                CASE WHEN v_diff_paid > 0 THEN 'OUT' ELSE 'IN' END,
                ABS(v_diff_paid),
                'purchase',
                NEW.id,
                'تعديل المبلغ المدفوع لفاتورة شراء رقم: ' || NEW.purchase_number
            );
        END IF;

        v_diff_remain := NEW.remaining_amount - OLD.remaining_amount;
        IF v_diff_remain <> 0 AND NEW.supplier_id IS NOT NULL THEN
            UPDATE "pos".suppliers
            SET current_balance = current_balance + v_diff_remain
            WHERE id = NEW.supplier_id;
        END IF;

    ELSIF (TG_OP = 'DELETE') THEN
        IF OLD.paid_amount > 0 THEN
            INSERT INTO "pos".cash_flow (type, amount, source_type, reference_id, description)
            VALUES ('IN', OLD.paid_amount, 'purchase', OLD.id, 'إلغاء واسترداد مالي لمشتريات محذوفة رقم: ' || OLD.purchase_number);
        END IF;

        IF OLD.remaining_amount > 0 AND OLD.supplier_id IS NOT NULL THEN
            UPDATE "pos".suppliers
            SET current_balance = current_balance - OLD.remaining_amount
            WHERE id = OLD.supplier_id;
        END IF;
    END IF;

    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_financial_purchase_head_all ON "pos".purchases;
CREATE TRIGGER trg_financial_purchase_head_all
AFTER INSERT OR UPDATE OR DELETE ON "pos".purchases
FOR EACH ROW
EXECUTE FUNCTION "pos".fn_trg_financial_purchase_head();


