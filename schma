-- ==========================================
-- 1. إعداد السكيما وتفعيل الإضافات المطلوبة
-- ==========================================
CREATE SCHEMA IF NOT EXISTS "pos";

-- تفعيل ميزة توليد معرفات الـ UUID عشوائياً في الـ Schema الحالية
CREATE EXTENSION IF NOT EXISTS "pgcrypto";
CREATE EXTENSION IF NOT EXISTS "plpgsql";

-- ==========================================
-- 2. بناء الجداول الأساسية داخل سكيما pos
-- ==========================================

-- جدول المستخدمين
CREATE TABLE IF NOT EXISTS "pos".users (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    email TEXT NOT NULL,
    password_hash TEXT NOT NULL,
    full_name TEXT,
    role TEXT NOT NULL DEFAULT 'user' CHECK (role IN ('admin', 'manager', 'user')),
    is_active BOOLEAN DEFAULT true,
    last_login TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now()
);

ALTER TABLE "pos".users DROP CONSTRAINT IF EXISTS users_email_key;
ALTER TABLE "pos".users ADD CONSTRAINT users_email_key UNIQUE (email);

-- جدول المنتجات
CREATE TABLE IF NOT EXISTS "pos".products (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    barcode TEXT,
    category TEXT,
    unit TEXT DEFAULT 'قطعة',
    cost_price NUMERIC(12,2) DEFAULT 0,
    sell_price NUMERIC(12,2) DEFAULT 0,
    stock_qty NUMERIC(12,3) DEFAULT 0,
    min_stock_qty NUMERIC(12,3) DEFAULT 5,
    is_active BOOLEAN DEFAULT true,
    image_url TEXT,
    notes TEXT,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now()
);

ALTER TABLE "pos".products DROP CONSTRAINT IF EXISTS products_barcode_key;
ALTER TABLE "pos".products ADD CONSTRAINT products_barcode_key UNIQUE (barcode);

-- جدول العملاء
CREATE TABLE IF NOT EXISTS "pos".customers (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    phone TEXT,
    email TEXT,
    address TEXT,
    tax_id TEXT,
    credit_limit NUMERIC(12,2) DEFAULT 0,
    current_balance NUMERIC(12,2) DEFAULT 0.00,
    notes TEXT,
    is_active BOOLEAN DEFAULT true,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول الموردين
CREATE TABLE IF NOT EXISTS "pos".suppliers (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    phone TEXT,
    email TEXT,
    address TEXT,
    tax_id TEXT,
    credit_limit NUMERIC(12,2) DEFAULT 0,
    current_balance NUMERIC(12,2) DEFAULT 0.00,
    notes TEXT,
    is_active BOOLEAN DEFAULT true,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول حركات المخازن التفصيلي (كارت الصنف)
CREATE TABLE IF NOT EXISTS "pos".inventory_transactions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    product_id UUID REFERENCES "pos".products(id) ON DELETE CASCADE,
    type TEXT NOT NULL CHECK (type IN ('IN', 'OUT')),
    qty NUMERIC(12,3) NOT NULL,
    source_type TEXT NOT NULL, -- 'invoice', 'purchase', 'manual'
    reference_id UUID,
    description TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول حركة الخزينة والتدفقات النقدية
CREATE TABLE IF NOT EXISTS "pos".cash_flow (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    type TEXT NOT NULL CHECK (type IN ('IN', 'OUT')),
    amount NUMERIC(12,2) NOT NULL,
    source_type TEXT NOT NULL,
    reference_id UUID,
    description TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول تصنيفات المصاريف
CREATE TABLE IF NOT EXISTS "pos".expense_categories (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name TEXT NOT NULL,
    created_at TIMESTAMPTZ DEFAULT now()
);

ALTER TABLE "pos".expense_categories DROP CONSTRAINT IF EXISTS expense_categories_name_key;
ALTER TABLE "pos".expense_categories ADD CONSTRAINT expense_categories_name_key UNIQUE (name);

-- جدول فواتير المبيعات
CREATE TABLE IF NOT EXISTS "pos".invoices (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    invoice_number TEXT NOT NULL,
    customer_id UUID REFERENCES "pos".customers(id) ON DELETE SET NULL,
    status TEXT DEFAULT 'paid' CHECK (status IN ('paid', 'pending', 'cancelled')),
    subtotal NUMERIC(12,2) DEFAULT 0,
    discount_amt NUMERIC(12,2) DEFAULT 0,
    tax_rate NUMERIC(5,2) DEFAULT 0,
    tax_amt NUMERIC(12,2) DEFAULT 0,
    total_amount NUMERIC(12,2) DEFAULT 0,
    paid_amount NUMERIC(12,2) DEFAULT 0,
    remaining_amount NUMERIC(12,2) GENERATED ALWAYS AS (total_amount - paid_amount) STORED,
    payment_method TEXT DEFAULT 'cash' CHECK (payment_method IN ('cash', 'card', 'transfer', 'credit')),
    notes TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

ALTER TABLE "pos".invoices DROP CONSTRAINT IF EXISTS invoices_invoice_number_key;
ALTER TABLE "pos".invoices ADD CONSTRAINT invoices_invoice_number_key UNIQUE (invoice_number);

-- جدول تفاصيل بنود فواتير المبيعات
CREATE TABLE IF NOT EXISTS "pos".invoice_items (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    invoice_id UUID NOT NULL REFERENCES "pos".invoices(id) ON DELETE CASCADE,
    product_id UUID REFERENCES "pos".products(id) ON DELETE SET NULL,
    name TEXT NOT NULL,
    qty NUMERIC(12,3) NOT NULL,
    unit_price NUMERIC(12,2) NOT NULL,
    discount NUMERIC(5,2) DEFAULT 0,
    total NUMERIC(12,2) NOT NULL,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول فواتير المشتريات
CREATE TABLE IF NOT EXISTS "pos".purchases (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    purchase_number TEXT NOT NULL,
    supplier_id UUID REFERENCES "pos".suppliers(id) ON DELETE SET NULL,
    status TEXT DEFAULT 'received' CHECK (status IN ('received', 'pending', 'cancelled')),
    subtotal NUMERIC(12,2) DEFAULT 0,
    discount_amt NUMERIC(12,2) DEFAULT 0,
    tax_amt NUMERIC(12,2) DEFAULT 0,
    total_amount NUMERIC(12,2) DEFAULT 0,
    paid_amount NUMERIC(12,2) DEFAULT 0,
    remaining_amount NUMERIC(12,2) GENERATED ALWAYS AS (total_amount - paid_amount) STORED,
    payment_method TEXT DEFAULT 'cash' CHECK (payment_method IN ('cash', 'card', 'transfer', 'credit')),
    notes TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

ALTER TABLE "pos".purchases DROP CONSTRAINT IF EXISTS purchases_purchase_number_key;
ALTER TABLE "pos".purchases ADD CONSTRAINT purchases_purchase_number_key UNIQUE (purchase_number);

-- جدول تفاصيل بنود فواتير المشتريات
CREATE TABLE IF NOT EXISTS "pos".purchase_items (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    purchase_id UUID NOT NULL REFERENCES "pos".purchases(id) ON DELETE CASCADE,
    product_id UUID REFERENCES "pos".products(id) ON DELETE SET NULL,
    name TEXT NOT NULL,
    qty NUMERIC(12,3) NOT NULL,
    unit_cost NUMERIC(12,2) NOT NULL,
    total NUMERIC(12,2) NOT NULL,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول المصاريف
CREATE TABLE IF NOT EXISTS "pos".expenses (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    category_id UUID REFERENCES "pos".expense_categories(id) ON DELETE SET NULL,
    description TEXT NOT NULL,
    amount NUMERIC(12,2) NOT NULL,
    paid_by TEXT,
    receipt_url TEXT,
    expense_date DATE,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول طابور رسائل الواتساب
CREATE TABLE IF NOT EXISTS "pos".whatsapp_queue (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    recipient TEXT NOT NULL,
    message TEXT NOT NULL,
    template_name TEXT,
    template_params JSONB,
    status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'sent', 'failed')),
    error_message TEXT,
    sent_at TIMESTAMPTZ,
    created_by UUID REFERENCES "pos".users(id) ON DELETE SET NULL,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول سجل المراجعة والتتبع والأمان
CREATE TABLE IF NOT EXISTS "pos".audit_log (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES "pos".users(id) ON DELETE SET NULL,
    table_name TEXT NOT NULL,
    record_id UUID,
    action TEXT NOT NULL,
    old_values JSONB,
    new_values JSONB,
    ip_address TEXT,
    user_agent TEXT,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- جدول طابور المزامنة
CREATE TABLE IF NOT EXISTS "pos".sync_queue (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES "pos".users(id) ON DELETE CASCADE,
    table_name TEXT NOT NULL,
    record_id UUID NOT NULL,
    operation TEXT NOT NULL CHECK (operation IN ('INSERT', 'UPDATE', 'DELETE')),
    data JSONB,
    synced BOOLEAN DEFAULT false,
    synced_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT now()
);


